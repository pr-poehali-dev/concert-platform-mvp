{
  "tests": [
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/?action=login",
      "body": { "password": "wrong" },
      "expectedStatus": 401,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Stats without token",
      "method": "GET",
      "path": "/?action=stats",
      "expectedStatus": 403,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Users without token",
      "method": "GET",
      "path": "/?action=users",
      "expectedStatus": 403,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Delete user without token",
      "method": "POST",
      "path": "/?action=delete_user",
      "body": { "id": "00000000-0000-0000-0000-000000000000" },
      "expectedStatus": 403,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Delete venue without token",
      "method": "POST",
      "path": "/?action=delete_venue",
      "body": { "id": "00000000-0000-0000-0000-000000000000" },
      "expectedStatus": 403,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Support unread count no user",
      "method": "GET",
      "path": "/?action=support_unread_count",
      "expectedStatus": 200,
      "expectedBody": { "count": 0 },
      "bodyMatcher": "partial"
    },
    {
      "name": "Support dialogs without token",
      "method": "GET",
      "path": "/?action=support_dialogs",
      "expectedStatus": 403,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "User details without token",
      "method": "GET",
      "path": "/?action=user_details&id=00000000-0000-0000-0000-000000000000",
      "expectedStatus": 403,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Test email without token",
      "method": "POST",
      "path": "/?action=test_email",
      "body": { "email": "test@example.com" },
      "expectedStatus": 403,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    }
  ]
}