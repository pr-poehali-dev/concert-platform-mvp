      "expectedStatus": 400,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "DM messages missing params",
      "method": "GET",
      "path": "/?action=dm_messages",
      "expectedStatus": 400,
