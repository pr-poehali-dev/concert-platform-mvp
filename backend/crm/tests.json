{
  "tests": [
    {
      "name": "No user_id returns 400",
      "method": "GET",
      "path": "/?action=companies_list",
      "expectedStatus": 400
    },
    {
      "name": "Companies list empty",
      "method": "GET",
      "path": "/?action=companies_list&user_id=00000000-0000-0000-0000-000000000001",
      "expectedStatus": 200,
      "expectedBody": {"companies": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Deals list empty",
      "method": "GET",
      "path": "/?action=deals_list&user_id=00000000-0000-0000-0000-000000000001",
      "expectedStatus": 200,
      "expectedBody": {"deals": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Tasks list empty",
      "method": "GET",
      "path": "/?action=tasks_list&user_id=00000000-0000-0000-0000-000000000001",
      "expectedStatus": 200,
      "expectedBody": {"tasks": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "Goals list empty",
      "method": "GET",
      "path": "/?action=goals_list&user_id=00000000-0000-0000-0000-000000000001",
      "expectedStatus": 200,
