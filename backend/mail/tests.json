{
  "tests": [
    {
      "name": "Accounts no user_id",
      "method": "GET",
      "path": "/?action=accounts",
      "expectedStatus": 400,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Accounts empty list",
      "method": "GET",
      "path": "/?action=accounts&user_id=00000000-0000-0000-0000-000000000099",
      "expectedStatus": 200,
      "expectedBody": { "accounts": [] },
      "bodyMatcher": "partial"
    },
    {
